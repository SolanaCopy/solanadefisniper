# Telegram MTProto credentials (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Telegram channel to monitor (username without @ or channel ID)
TELEGRAM_CHANNEL=

# Solana wallet private key (base58 encoded)
SOLANA_PRIVATE_KEY=

# Solana RPC endpoint (Helius)
# Get your API key from: https://dashboard.helius.dev
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Trading settings
BUY_AMOUNT_SOL=0.01
SLIPPAGE_BPS=500
AUTO_BUY=false

# Multi-caller strategy: buy when N unique callers mention the same token
MIN_CALLERS=3
# Ignore tokens older than X minutes
MAX_AGE_MINUTES=60

# Auto-sell: sell X% when token hits Nx YOUR buy price (not from original call)
# SpyDeFi shows tokens after x2+, so we enter late — use lower targets
TAKE_PROFIT_X=1.5
SELL_PERCENTAGE=100
# How often to check prices (ms)
PRICE_CHECK_INTERVAL_MS=15000

# Server port for dashboard
PORT=3001
